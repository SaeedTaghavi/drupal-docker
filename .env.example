# Project Settings
# Use a unique name to avoid conflicts with other Docker projects
COMPOSE_PROJECT_NAME=drupal_project
# The port where Drupal will be accessible (e.g., 80, 8080)
DRUPAL_PORT=80

# Database Credentials
# These will be used to initialize the MariaDB container
DB_NAME=drupal_db
DB_USER=drupal_user
DB_PASSWORD=change_me_to_something_secure
DB_ROOT_PASSWORD=change_me_to_something_secure
